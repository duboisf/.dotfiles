#!/usr/bin/env bash
set -euo pipefail

MAX_JOBS="${GH_PRS_MAX_JOBS:-10}"
LISTEN_PORT=$((RANDOM % 10000 + 20000))

TMPDIR=$(mktemp -d /tmp/gh-prs.XXXXXX)
cleanup() {
    local pids
    pids=$(jobs -p 2>/dev/null) || true
    [[ -n "$pids" ]] && kill $pids 2>/dev/null || true
    wait 2>/dev/null || true
    rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

for cmd in gh fzf jq; do
    command -v "$cmd" &>/dev/null || { echo "Required: $cmd" >&2; exit 1; }
done

if [[ "${COLORTERM:-}" =~ ^(truecolor|24bit)$ ]]; then
    FZF_BG_SEL='#3b4261'
else
    FZF_BG_SEL=240
fi

OPEN_CMD="xdg-open"
[[ "$(uname)" == "Darwin" ]] && OPEN_CMD="open"

printf "\033[2mFetching all your open PRs...\033[0m\n" >&2

# --- Phase 1: Fetch all my open PRs across all of GitHub ---
gh search prs --author=@me --state=open --limit=200 \
    --json repository,number,title,url,updatedAt,isDraft \
    --jq '.[] | [.repository.nameWithOwner, (.number|tostring), .title, .url, .updatedAt, (if .isDraft then "draft" else "" end)] | @tsv' \
    2>/dev/null | sort -t$'\t' -k5 -r | cut -f1-4,6 > "$TMPDIR/basic.tsv"

[[ -s "$TMPDIR/basic.tsv" ]] || { echo "No open PRs found." >&2; exit 0; }

total=$(wc -l < "$TMPDIR/basic.tsv")
printf "\033[2mFound %d PR(s)\033[0m\n" "$total" >&2

# --- Display formatting ---
# Compute column widths from data
repo_w=$(awk -F'\t' 'BEGIN{m=4} {l=length($1); if(l>m) m=l} END{print m}' "$TMPDIR/basic.tsv")
num_w=$(awk -F'\t' 'BEGIN{m=2} {l=length($2)+1; if(l>m) m=l} END{print m}' "$TMPDIR/basic.tsv")

# ANSI colors
C_GREEN=$'\033[32m' C_RED=$'\033[31m' C_YELLOW=$'\033[33m'
C_BRIGHT_BLUE=$'\033[94m' C_DIM=$'\033[2m' C_RESET=$'\033[0m'

# Pad then wrap in color (so padding isn't thrown off by escape codes)
colorize() {
    local val="$1" len=${#1} pad
    (( pad = 14 - len, pad = pad > 0 ? pad : 0 ))
    local padded="${val}$(printf "%${pad}s" "")"
    case "$val" in
        ✓*) printf "%s%s%s" "$C_GREEN"  "$padded" "$C_RESET" ;;
        ✗*) printf "%s%s%s" "$C_RED"    "$padded" "$C_RESET" ;;
        ◑*|…*) printf "%s%s%s" "$C_YELLOW" "$padded" "$C_RESET" ;;
        ◯*) printf "%s%s%s" "$C_BRIGHT_BLUE" "$padded" "$C_RESET" ;;
        —*) printf "%s%s%s" "$C_DIM"    "$padded" "$C_RESET" ;;
        *)  printf "%s" "$padded" ;;
    esac
}

# Output: visible columns \t URL (hidden, used by ctrl-o)
fmtline() {
    printf "%-${repo_w}s  #%-${num_w}s  %s  %s  %s  %s\t%s\n" \
        "$1" "$2" "$(colorize "$3")" "$(colorize "$4")" "$(colorize "$5")" "$6" "$7"
}

HEADER_COLS=$(fmtline "REPO" "PR" "REVIEW" "CHECKS" "AUTO-MERGE" "TITLE" "" | cut -f1)

# Initial display with loading placeholders
{
    while IFS=$'\t' read -r repo num title url draft; do
        dtag=""
        [[ "$draft" == "draft" ]] && dtag="${C_DIM}[draft]${C_RESET} "
        fmtline "$repo" "$num" "   ···" "   ···" "   ···" "${dtag}${title}" "$url"
    done < "$TMPDIR/basic.tsv"
} > "$TMPDIR/display.tsv"

# --- Refresh script (used for initial enrichment and ctrl-r) ---
HINTS="ctrl-o: open │ alt-m: auto-merge │ alt-d: draft/ready │ ctrl-r: refresh"
{
    cat << REOF
#!/usr/bin/env bash
set -uo pipefail
TMPDIR='$TMPDIR'
LISTEN_PORT=$LISTEN_PORT
MAX_JOBS=$MAX_JOBS
C_GREEN=\$'\\033[32m' C_RED=\$'\\033[31m' C_YELLOW=\$'\\033[33m'
C_BRIGHT_BLUE=\$'\\033[94m' C_DIM=\$'\\033[2m' C_RESET=\$'\\033[0m'
REOF
    declare -f colorize fmtline
    cat << 'REOF'

if [[ "${1:-}" != "--enrich-only" ]]; then
    gh search prs --author=@me --state=open --limit=200 \
        --json repository,number,title,url,updatedAt,isDraft \
        --jq '.[] | [.repository.nameWithOwner, (.number|tostring), .title, .url, .updatedAt, (if .isDraft then "draft" else "" end)] | @tsv' \
        2>/dev/null | sort -t$'\t' -k5 -r | cut -f1-4,6 > "$TMPDIR/basic.tsv"
    [[ -s "$TMPDIR/basic.tsv" ]] || exit 0
fi

repo_w=$(awk -F'\t' 'BEGIN{m=4} {l=length($1); if(l>m) m=l} END{print m}' "$TMPDIR/basic.tsv")
num_w=$(awk -F'\t' 'BEGIN{m=2} {l=length($2)+1; if(l>m) m=l} END{print m}' "$TMPDIR/basic.tsv")
HEADER_COLS=$(fmtline "REPO" "PR" "REVIEW" "CHECKS" "AUTO-MERGE" "TITLE" "" | cut -f1)

n=0
{
    while IFS=$'\t' read -r repo num title url draft; do
        (
            pr_data=$(gh pr view "$num" --repo "$repo" \
                --json reviewDecision,reviewRequests,reviews,autoMergeRequest,isDraft 2>/dev/null || echo '{}')

            dtag=""
            is_draft=$(echo "$pr_data" | jq -r '.isDraft // false' 2>/dev/null)
            [[ "$is_draft" == "true" ]] && dtag="${C_DIM}[draft]${C_RESET} "

            rv=$(echo "$pr_data" | jq -r '
                    if .reviewDecision == "APPROVED" then "✓ approved"
                    elif .reviewDecision == "CHANGES_REQUESTED" then "✗ changes"
                    elif (.reviews | length) > 0 then "◑ in review"
                    elif (.reviewRequests | length) > 0 then "◯ requested"
                    else "— none"
                    end' 2>/dev/null || echo "? error")

            am=$(echo "$pr_data" | jq -r '
                    if .autoMergeRequest != null then "✓ auto"
                    else "—"
                    end' 2>/dev/null || echo "?")

            ck=$(gh pr checks "$num" --repo "$repo" --json name,state 2>/dev/null \
                | jq -r '
                    if length == 0 then "— none"
                    else
                        [.[].state] |
                        { s: map(select(. == "SUCCESS")) | length,
                          f: map(select(. == "FAILURE")) | length,
                          p: map(select(. == "PENDING" or . == "QUEUED" or . == "IN_PROGRESS")) | length } |
                        if .f > 0 then "✗ \(.f) fail"
                        elif .p > 0 then "… \(.p) pend"
                        else "✓ \(.s) pass"
                        end
                    end' 2>/dev/null || echo "? error")

            fmtline "$repo" "$num" "$rv" "$ck" "$am" "${dtag}${title}" "$url"
        ) &
        (( ++n % MAX_JOBS == 0 )) && wait
    done < "$TMPDIR/basic.tsv"
    wait
} > "$TMPDIR/enriched.tsv"

HINTS="ctrl-o: open │ alt-m: auto-merge │ alt-d: draft/ready │ ctrl-r: refresh"
curl -s -XPOST "localhost:$LISTEN_PORT" \
    -d "reload(cat '$TMPDIR/enriched.tsv')+change-header($HINTS │ ✓ loaded
$HEADER_COLS)" \
    2>/dev/null || true
REOF
} > "$TMPDIR/refresh.sh"
chmod +x "$TMPDIR/refresh.sh"

# --- Background enrichment ---
bash "$TMPDIR/refresh.sh" --enrich-only &

# --- fzf ---
fzf \
    --delimiter=$'\t' \
    --with-nth=1 \
    --header "$HINTS │ loading...
$HEADER_COLS" \
    --bind "ctrl-o:execute-silent($OPEN_CMD {2})+abort" \
    --bind "ctrl-r:execute-silent(bash '$TMPDIR/refresh.sh' &)+change-header($HINTS │ refreshing...
$HEADER_COLS)" \
    --bind "alt-m:execute(url={2}; repo=\${url#https://github.com/}; repo=\${repo%%/pull/*}; num=\${url##*/}; gh pr merge \"\$num\" --repo \"\$repo\" --auto && { grep -Fv \"\$url\" '$TMPDIR/display.tsv' > '$TMPDIR/display.tmp' && mv '$TMPDIR/display.tmp' '$TMPDIR/display.tsv'; grep -Fv \"\$url\" '$TMPDIR/enriched.tsv' > '$TMPDIR/enriched.tmp' && mv '$TMPDIR/enriched.tmp' '$TMPDIR/enriched.tsv'; } 2>/dev/null)+reload(cat '$TMPDIR/enriched.tsv' 2>/dev/null || cat '$TMPDIR/display.tsv')" \
    --bind "alt-d:execute(url={2}; repo=\${url#https://github.com/}; repo=\${repo%%/pull/*}; num=\${url##*/}; if gh pr view \"\$num\" --repo \"\$repo\" --json isDraft -q .isDraft | grep -q true; then gh pr ready \"\$num\" --repo \"\$repo\"; else gh pr ready --undo \"\$num\" --repo \"\$repo\"; fi)" \
    --bind "enter:execute-silent($OPEN_CMD {2})+abort" \
    --listen "$LISTEN_PORT" \
    --reverse \
    --no-sort \
    --ansi \
    --color "bg+:$FZF_BG_SEL" \
    < "$TMPDIR/display.tsv" || true
